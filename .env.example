# Enable execution of real integration tests (non-mocked)
RUN_REAL_TESTS=1

# Optional: Blender bridge endpoint
BLENDER_HOST=127.0.0.1
BLENDER_PORT=8765
BLENDER_TIMEOUT_MS=5000

# Optional: override Poly Haven API base (default: https://api.polyhaven.com)
POLYHAVEN_API_BASE=https://api.polyhaven.com
